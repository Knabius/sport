component StartButton inherits Rectangle {
    in-out property <bool> status;

    callback button_pressed();

    height: 300px;
    width: self.height;
    background: status ? #026F8F : #B71C1C;
    border-radius: self.height/2;
    border-width: 2px;
    border-color: Colors.black;
    clip: true;
    //TODO button invisible wenn fertig und wieder visible wenn weiter
    
    Text {
        text: status ? "Start" : "Stop";
        font-size: 40px;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { 
            root.button_pressed();
        }
    }
}

export component MainWindow inherits Window {
    callback start_pressed(string, string);

    in-out property <bool> floor_input_invalid: false;
    in-out property <int> initial_floor_value;
    in-out property <bool> ceil_input_invalid: false;
    in-out property <int> initial_ceil_value;

    in-out property <bool> start_button_status: true;

    in-out property <color> floor_color: #41667188;
    in-out property <color> ceil_color: #41667188;
    animate floor_color {duration: 500ms; easing: ease-out;}
    animate ceil_color {duration: 500ms; easing: ease-out;}

    flash_timer := Timer {
        interval: 50ms;
        triggered => {
            if (floor_input_invalid == true) {
                root.floor_color = #41667188;
                floor_input_invalid = false;
            }
            if (ceil_input_invalid == true) {
                root.ceil_color = #41667188;
                ceil_input_invalid = false;
            }
            self.running = false;
        }
    }

    public function text_input_flash() {
        if (floor_input_invalid == true) {
            root.floor_color = #FF0000;
        }
        if (ceil_input_invalid == true) {
            root.ceil_color = #FF0000;
        }
        flash_timer.running = true;
    }

    width: 1200px;
    height: 800px;
    HorizontalLayout {
        alignment: center;
        VerticalLayout {
            spacing: 20px;
            alignment: center;
            HorizontalLayout {
                alignment: center;
                start_button := StartButton {
                    status: start_button_status;
                    button_pressed => {
                        root.start_pressed(floor_input.text, ceil_input.text);
                    }
                }
            }
            //TODO auch beide unsichtbar und danach wieder visible
            HorizontalLayout {
                alignment: center;
                spacing: 10px;
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: floor_color;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Colors.black;
                    
                    floor_input := TextInput {
                        color: #FFFFFF;
                        font-size: 20px;
                        //selection-background-color: #026F8F;
                        text: initial_floor_value;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: ceil_color;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Colors.black;
                    
                    ceil_input := TextInput {
                        color: #FFFFFF;
                        font-size: 20px;
                        //selection-background-color: #026F8F;
                        text: initial_ceil_value;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }            
            }
        }
    }
}