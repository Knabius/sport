import { TabWidget, VerticalBox, HorizontalBox, Switch, ListView, ComboBox } from "std-widgets.slint";

global Palette {
    property <color> primary: #3498db;
    property <color> secondary: #2ecc71;
    property <color> accent: #e74c3c;
    property <color> text_primary: #333333;
    property <color> text_secondary: #555555;
    property <color> text_on_primary: #ffffff;
    property <color> text_on_accent: #ffffff;
    property <color> surface: #f4f6f6;
    property <color> background: #ffffff;
    property <color> border: #dddddd;
}

//Enums
enum CurrentView {
    BasicButton,
    RepInput,
    Settings
}

//Structs
export struct Exercise {
    name: string,
    activation_status: bool,
}

//Widgets
component StartButton inherits Rectangle {
    in-out property <bool> status;
    in-out property <int> time;

    callback button_pressed();

    height: 300px;
    width: self.height;
    background: status ? Palette.primary : Palette.accent;
    border-radius: self.height/2;
    border-width: 2px;
    border-color: Palette.border;
    clip: true;
    
    Text {
        text: status ? "Start" : time + "s";
        font-size: 40px;
        color: Palette.text_on_primary;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { 
            root.button_pressed();
        }
    }
}

component RepInput inherits Rectangle {
    callback save_reps(string);

    in property <string> exercise;
    padding: 15px; // Added padding

    VerticalLayout {
        alignment: center;
        spacing: 10px; // Adjusted spacing
        HorizontalLayout {
            alignment: center;
            Text {
                text: exercise + "s";
                font-size: 40px;
                color: Palette.primary;
            }
        }
        HorizontalLayout {
            alignment: center;
            padding: 10px;
            Text {
                text: "Enter amount of completed reps below";
                font-size: 15px;
                color: Palette.text_secondary;
            }
        }
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 150px;
                height: 40px;
                background: Palette.surface;
                border-radius: 6px; // Standardized
                border-width: 1px;
                border-color: Palette.border;
        
                reps := TextInput {
                    color: Palette.text_primary;
                    font-size: 20px;
                    text: "0";
                    input-type: number;
                    horizontal-alignment: center;
                    vertical-alignment: center;

                    accepted => {
                        root.save_reps(reps.text);
                        reps.text = "0";
                    }
                }
            }
        }
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 80px;
                height: 40px;
                background: Palette.primary;
                border-radius: 6px; // Standardized
                border-width: 1px;
                border-color: Palette.border;
    
                Text {
                    text: "Save";
                    font-size: 20px;
                    color: Palette.text_on_primary;
                }

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { 
                        root.save_reps(reps.text);
                        reps.text = "0";
                    }
                }
            }
        }
    }
}

component BasicButton {
    callback start_pressed(string, string);

    //Interval Inputs
    in-out property <int> initial_floor_value;
    in-out property <int> initial_ceil_value;

    //Start Button
    in-out property <bool> start_button_status: true;
    in-out property <int> passed_time: 0;

    HorizontalLayout {
        alignment: center;
        VerticalLayout {
            spacing: 20px;
            alignment: center;
            HorizontalLayout {
                alignment: center;
                start_button := StartButton {
                    
                    time: passed_time;
                    status: start_button_status;
                    button_pressed => {
                        root.start_pressed(floor_input.text, ceil_input.text);
                    }
                }
            }
            HorizontalLayout {
                alignment: center;
                spacing: 10px;
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: Palette.surface;
                    border-radius: 6px; // Standardized
                    border-width: 1px;
                    border-color: Palette.border;
                    
                    floor_input := TextInput {
                        color: Palette.text_primary;
                        font-size: 20px;
                        input-type: number;
                        text: initial_floor_value;
                        horizontal-alignment: center;
                        vertical-alignment: center;

                        accepted => {
                            root.start_pressed(floor_input.text, ceil_input.text);
                        }
                    }
                }
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: Palette.surface;
                    border-radius: 6px; // Standardized
                    border-width: 1px;
                    border-color: Palette.border;
                    
                    ceil_input := TextInput {
                        color: Palette.text_primary;
                        font-size: 20px;
                        input-type: number;
                        text: initial_ceil_value;
                        horizontal-alignment: center;
                        vertical-alignment: center;

                        accepted => {
                            root.start_pressed(floor_input.text, ceil_input.text);
                        }
                    }
                }            
            }
        }
    }
}

component SettingsButton {
    callback open_settings();

    // x and y are set in MainWindow during instantiation for top-right positioning
    Rectangle {
        background: Palette.surface; // Changed background
        border-radius: 10px;
        width: 50px;
        height: 50px;
        border-width: 0px; // Removed border
        // border-color: Palette.border; 
        
        Image {
            width: parent.width;
            height: parent.height;
            source: @image-url("resources/icon_menu.png");
        }

        TouchArea {
            clicked => {
                open_settings();
            }
        }
    }
}

component Settings {
    callback changed_general(bool);
    callback changed_activation(string);
    callback add_exercise(string, string);
    callback remove_exercise(string);
    callback add_reps(string, string);

    in property <bool> setting_general_doubles;
    in-out property <[Exercise]> exercises;
    in-out property <[string]> exercise_names;
    in-out property <bool> add_exercise_vis: false;
    in-out property <bool> remove_exercise_vis: false;
    in-out property <bool> add_reps_vis: false;

    width: 600px;
    height: 400px;

    Rectangle {
        y: -140px;
        width: 200px;
        height: 80px;
        background: add_reps_vis ? Palette.accent : Palette.primary;
        border-radius: 6px; // Standardized
        border-width: 2px;
        border-color: Palette.border;
        
        Text {
            text: "Add Reps";
            font-size: 30px;
            color: Palette.text_on_primary;
        }

        TouchArea {
            clicked => {
                add_reps_vis = !add_reps_vis;
                add_rep_box.current-index = 0;
                add_reps_input.text = "Reps";
            }
        }
    }

    Rectangle { // "Add Reps" popup
        visible: add_reps_vis;
        width: 400px;
        height: 300px; // Or make it intrinsic based on content + padding
        background: Palette.surface;
        border-color: Palette.border;
        border-width: 1.5px;
        border-radius: 8px; // Standardized for popup

        VerticalBox {
            alignment: center;
            spacing: 10px; // Added spacing
            padding: 10px; // Added padding
            HorizontalBox {
                alignment: center;
                spacing: 10px; // Spacing between ComboBox and TextInput

                add_rep_box := ComboBox {
                    model: exercise_names;
                    height: 35px; // Consistent height
                }
        
                add_reps_input := TextInput {
                    text: "Reps";
                    font-size: 20px;
                    color: Palette.text_primary;
                    horizontal-alignment: center;
                    vertical-alignment: center;

                    accepted => {
                        add_reps(add_rep_box.current-value, add_reps_input.text);
                        add_reps_vis = !add_reps_vis;
                    }
                }
            }
            HorizontalBox {
                alignment: center;

                Rectangle {
                    width: 80px;
                    height: 40px;
                    background: Palette.primary;
                    border-radius: 6px; // Standardized
                    border-width: 1px;
                    border-color: Palette.border;
                    
                    Text {
                        text: "Add";
                        font-size: 20px;
                        color: Palette.text_on_primary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
        
                    TouchArea {
                        clicked => {
                            add_reps(add_rep_box.current-value, add_reps_input.text);
                            add_reps_vis = !add_reps_vis;
                        }
                    }
                }
            }
        }
    }

    Rectangle { // Main settings area with TabWidget
        visible: !add_reps_vis;
        border-radius: 8px; // Standardized for container
        border-width: 1px;
        border-color: Palette.border;
        background: Palette.background;
        TabWidget {
            Tab {
                title: "General";
                Rectangle {
                    background: Palette.surface;
                    padding: 10px; // Added padding to tab content area
                    VerticalBox {
                        alignment: start;
                        //REMINDER statt doppel rectangle vllt vertbox mit spacing
                        Rectangle { // Outer container for "Doubles" setting
                            width: 100%; // Fill parent tab area
                            // height: 40px; // Height can be intrinsic or set
                            border-width: 0px; // No border for this outer one
                            padding: 5px; // Adjusted padding
                            // border-color: transparent; 
                            
                            Rectangle { // Inner container with the border
                                width: 100%; // Fill outer rectangle
                                height: 35px;
                                border-width: 1.5px;
                                border-radius: 6px; // Standardized
                                border-color: Palette.border;
                                background: Palette.background;
                                HorizontalBox {
                                    padding: 5px; // Internal padding for content
                                    spacing: 10px; // Spacing between text and switch
                                    vertical-alignment: center; // Align items vertically
                                    Text {
                                        text: "Doubles";
                                        font-size: 16px;
                                        color: Palette.text_primary;
                                    }
                
                                    doubles := Switch {
                                        checked: setting_general_doubles;
                                        toggled => {
                                            changed_general(doubles.checked);
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
                                                
            Tab {
                title: "Exercises";
                Rectangle { 
                    background: Palette.surface;
                    padding: 10px; // Added padding to tab content area
                VerticalBox {
                    HorizontalBox { // For add/remove icons
                        alignment: center;
                        spacing: 10px; // Adjusted spacing
                        Rectangle {
                            height: 30px;
                            width: 30px;
                            background: add_exercise_vis ? Palette.accent : Palette.primary;
                            border-radius: 6px; // Standardized
                            border-width: 0px; // Removed border
                            
                            Image {
                                width: parent.width*0.6;
                                height: parent.height*0.6;
                                source: @image-url("resources/icon_plus.png");
                            }

                            TouchArea {
                                enabled: !remove_exercise_vis;
                                clicked => {
                                    add_exercise_vis = !add_exercise_vis;
                                }
                            }
                        }

                        Rectangle {
                            height: 30px;
                            width: 30px;
                            background: remove_exercise_vis ? Palette.accent : Palette.primary;
                            border-radius: 6px; // Standardized
                            border-width: 0px; // Removed border

                            Image {
                                width: parent.width*0.6;
                                height: parent.height*0.5;
                                source: @image-url("resources/icon_minus.png");
                            }

                            TouchArea {
                                enabled: !add_exercise_vis;
                                clicked => {
                                    remove_exercise_vis = !remove_exercise_vis;
                                }
                            }
                        }
                    }
                                        
                    // New VerticalLayout to wrap ListView and Add Exercise form
                    VerticalLayout {
                        spacing: 10px; // Spacing between ListView/form and the icon buttons above
                                        
                        if !add_exercise_vis:
                        ListView {
                            for data[i] in exercises:
                            Rectangle { // ListView item
                                width: 100%; // Fill available width
                                height: 40px;
                                border-width: 1px; 
                                padding: 5px; // Adjusted padding for list item
                                border-color: Palette.border;
                                border-radius: 6px; // Standardized
                                
                                HorizontalBox { // Holds content and remove button
                                    alignment: center;
                                    spacing: 5px; // Spacing between content area and remove button

                                    Rectangle { // Content area (text and switch)
                                        width: remove_exercise_vis ? parent.width - 30px - 5px : 100%; // Dynamic width
                                        height: 100%; 
                                        border-width: 0px; // No border for this inner rect
                                        background: Palette.background;
                                        animate width {
                                             easing: ease-in;
                                             duration: 300ms;
                                        }
                    
                                        HorizontalBox { // Inner content layout
                                            padding: 5px; 
                                            spacing: 5px; 
                                            vertical-alignment: center;
                                            Text {
                                                text: data.name;
                                                font-size: 16px;
                                                color: Palette.text_primary;
                                            }
                
                                            Switch {
                                                checked: data.activation_status;
                                                toggled => {
                                                    exercises[i].activation_status = !exercises[i].activation_status;
                                                    changed_activation(exercises[i].name);
                                                }
                                            }
                                        }
                                    }
                                    
                                    if remove_exercise_vis:
                                    Rectangle { // Remove button
                                        width: 30px;
                                        height: 30px;
                                        background: Palette.primary;
                                        border-radius: 6px; // Standardized

                                        Text {
                                            text: "-";
                                            color: Palette.text_on_primary;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }

                                        TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            clicked => {
                                                remove_exercise(exercises[i].name);
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if add_exercise_vis :
                        VerticalBox { // "Add Exercise" form container
                            // height property removed, let it size by content or parent
                            alignment: center;
                            // spacing: 10px; // This VB is for the form itself, inner VB will space fields
                            HorizontalBox { // To center the form Rectangle
                                alignment: center;
                                Rectangle { // Form background and border
                                    background: Palette.surface;
                                    width: 300px; 
                                    // height: 200px; // Let height be intrinsic
                                    border-radius: 8px; // Standardized for form container
                                    border-color: Palette.border;
                                    border-width: 1px;
                                    padding: 15px; // Padding for the form content
                                    
                                    VerticalBox { // Layout for form fields
                                        spacing: 10px; // Spacing between form fields
                                        alignment: center;

                                        HorizontalBox { // Name input field
                                            alignment: center;
                                            add_exercise_name := TextInput {
                                                color: Palette.text_primary;
                                                font-size: 20px;
                                                text: "Name";
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                                // width: parent.width * 0.9; // Consider relative width
                                            }
                                        }

                                        HorizontalBox { // Exercise type ComboBox
                                            alignment: center;
                                            combo := ComboBox {
                                                height: 35px;
                                                width: 120px; // Wider for "Time" and "Reps"
                                                // current-value and model are already set
                                            }
                                        }

                                        HorizontalBox { // Save button
                                            alignment: center;
                                            Rectangle {
                                                width: 80px;
                                                height: 40px;
                                                background: Palette.primary;
                                                border-radius: 6px; // Standardized
                                                border-width: 1px;
                                                border-color: Palette.border;
                                    
                                                Text {
                                                    text: "Save";
                                                    font-size: 20px;
                                                    color: Palette.text_on_primary;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                
                                                TouchArea {
                                                    width: parent.width;
                                                    height: parent.height;
                                                    clicked => {
                                                        add_exercise(add_exercise_name.text, combo.current-value);
                                                        add_exercise_vis = !add_exercise_vis;
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    } // End of new VerticalLayout wrapper
                }
            }
            Tab {
                title: "Profiles";
                Rectangle {
                    background: Palette.surface;
                    padding: 10px; // Added padding to tab content area
                }
            }
        }
    }
}

//MainWidget
export component MainWindow inherits Window {
    callback start_pressed(string, string);
    callback save_reps(string);
    callback changed_general_settings(bool);
    callback changed_activation_settings(string);
    callback add_exercise(string, string);
    callback remove_exercise(string);
    callback add_reps(string, string);
    
    //Interval Inputs
    in-out property <bool> floor_input_invalid: false;
    in-out property <int> initial_floor_value;
    in-out property <bool> ceil_input_invalid: false;
    in-out property <int> initial_ceil_value;
    
    //Start Button
    in-out property <bool> start_button_status: true;
    in-out property <int> passed_time: 0;
    
    //Exercise
    in property <string> chosen_exercise: "";

    //View
    in-out property <CurrentView> current_view: CurrentView.BasicButton;

    //Settings
    in-out property <bool> setting_general_doubles: true;
    in-out property <[Exercise]> exercises;
    in-out property <[string]> exercise_names;

    width: 1200px;
    height: 800px;
    background: Palette.background;

    RepInput {
        visible: current_view == CurrentView.RepInput;
        exercise: chosen_exercise;
        save_reps(reps) => {
            root.save_reps(reps);
        }
    }

    BasicButton {
        visible: current_view == CurrentView.BasicButton;
        initial_floor_value: initial_floor_value;
        initial_ceil_value: initial_ceil_value;
        start_button_status: start_button_status;
        passed_time: passed_time;
        start_pressed(floor, ceil) => {
            start_pressed(floor, ceil);
            passed_time = 0;
        }
    }
    
    settings_button := SettingsButton {
        x: parent.width - self.width - 20px; // Position top-right
        y: 20px;                             // With 20px margin
        property <CurrentView> last_view;
        open_settings => {
            if current_view == CurrentView.Settings {
                current_view = last_view;
            } else {
                last_view = current_view;
                current_view = CurrentView.Settings;
            }
        }
    }

    Settings {
        visible: current_view == CurrentView.Settings;
        setting_general_doubles: setting_general_doubles;
        exercises: exercises;
        exercise_names: exercise_names;
        changed_general(doubles) => {
            changed_general_settings(doubles);
        }
        changed_activation(name) => {
            changed_activation_settings(name);
        }
        add_exercise(name, type) => {
            add_exercise(name, type);
        }
        remove_exercise(name) => {
            remove_exercise(name);
        }
        add_reps(name, reps) => {
            add_reps(name, reps);
        }
    }
}