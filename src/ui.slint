component StartButton inherits Rectangle {
    in-out property <bool> status;
    in-out property <int> time;

    callback button_pressed();

    height: 300px;
    width: self.height;
    background: status ? #026F8F : #B71C1C;
    border-radius: self.height/2;
    border-width: 2px;
    border-color: Colors.black;
    clip: true;
    
    Text {
        text: status ? "Start" : time + "s";
        font-size: 40px;
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        clicked => { 
            root.button_pressed();
        }
    }
}

component RepInput inherits Rectangle {
    callback save_reps(string);

    in property <string> exercise;

    VerticalLayout {
        alignment: center;
        spacing: 5px;
        HorizontalLayout {
            alignment: center;
            Text {
                text: exercise + "s";
                font-size: 40px;
                color: #026F8F;
            }
        }
        HorizontalLayout {
            alignment: center;
            padding: 10px;
            Text {
                text: "Enter amount of completed reps below";
                font-size: 15px;
            }
        }
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 150px;
                height: 40px;
                background: #41667188;
                border-radius: 10px;
                border-width: 1px;
                border-color: Colors.black;
        
                reps := TextInput {
                    color: Colors.white;
                    font-size: 20px;
                    text: "0";
                    input-type: number;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 80px;
                height: 40px;
                background: #026F8F;
                border-radius: 10px;
                border-width: 1px;
                border-color: Colors.black;
    
                Text {
                    text: "Save";
                    font-size: 20px;
                }

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    clicked => { 
                        root.save_reps(reps.text);
                        reps.text = "0";
                    }
                }
            }
        }
    }
}

enum CurrentView {
    BasicButton,
    RepInput
}

export component MainWindow inherits Window {
    in-out property <CurrentView> current_view: CurrentView.BasicButton;

    callback start_pressed(string, string);
    callback save_reps(string);

    in-out property <bool> floor_input_invalid: false;
    in-out property <int> initial_floor_value;
    in-out property <bool> ceil_input_invalid: false;
    in-out property <int> initial_ceil_value;

    in-out property <bool> center_visibility: true;

    in-out property <bool> start_button_status: true;
    in-out property <int> passed_time: 0;

    in property <string> chosen_exercise: "";

    in-out property <color> floor_color: #41667188;
    in-out property <color> ceil_color: #41667188;
    animate floor_color {duration: 500ms; easing: ease-out;}
    animate ceil_color {duration: 500ms; easing: ease-out;}

    flash_timer := Timer {
        interval: 50ms;
        triggered => {
            if (floor_input_invalid == true) {
                root.floor_color = #41667188;
                floor_input_invalid = false;
            }
            if (ceil_input_invalid == true) {
                root.ceil_color = #41667188;
                ceil_input_invalid = false;
            }
            self.running = false;
        }
    }

    public function text_input_flash() {
        if (floor_input_invalid == true) {
            root.floor_color = #FF0000;
        }
        if (ceil_input_invalid == true) {
            root.ceil_color = #FF0000;
        }
        flash_timer.running = true;
    }

    width: 1200px;
    height: 800px;

    RepInput {
        visible: current_view == CurrentView.RepInput;
        exercise: chosen_exercise;
        save_reps(reps) => {
            root.save_reps(reps);
        }
    }

    HorizontalLayout {
        visible: current_view == CurrentView.BasicButton;
        alignment: center;
        VerticalLayout {
            spacing: 20px;
            alignment: center;
            HorizontalLayout {
                alignment: center;
                start_button := StartButton {
                    time: passed_time;
                    status: start_button_status;
                    button_pressed => {
                        root.start_pressed(floor_input.text, ceil_input.text);
                        passed_time = 0;
                    }
                }
            }
            HorizontalLayout {
                alignment: center;
                spacing: 10px;
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: floor_color;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Colors.black;
                    
                    floor_input := TextInput {
                        color: #FFFFFF;
                        font-size: 20px;
                        input-type: number;
                        text: initial_floor_value;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 150px;
                    height: 40px;
                    background: ceil_color;
                    border-radius: 10px;
                    border-width: 1px;
                    border-color: Colors.black;
                    
                    ceil_input := TextInput {
                        color: #FFFFFF;
                        font-size: 20px;
                        input-type: number;
                        text: initial_ceil_value;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }            
            }
        }
    }
}

